{
  "name": "tasksheet-orchestrator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix ./client run dev\" \"npm --prefix ./server start\"",
    "postinstall": "npm install --prefix ./client && npm install --prefix ./server",
    "build": "cd client && npm install && npm run build && cp -r dist ../server/public",
    "start": "npm --prefix ./server start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
